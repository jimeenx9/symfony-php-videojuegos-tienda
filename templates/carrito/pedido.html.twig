{% extends 'layout.html.twig' %}

{% block title %}Confirmar pedido{% endblock %}

{% block contenido %}
<div class="container mt-4">

    <h2>Confirmar pedido</h2>
    <br>

    <table class="table table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Producto</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
            </tr>
        </thead>

        <tbody>
        {% for item in articulos %}
            <tr>
                <td>
                    <div class="d-flex align-items-center">

                        {% if item.articulo.imagen %}
                            <img src="{{ asset('img/' ~ item.articulo.imagen) }}"
                                 width="60"
                                 class="me-3">
                        {% endif %}

                        <strong>{{ item.articulo.nombre }}</strong>
                    </div>
                </td>

                <td>{{ item.articulo.precioFinal }} €</td>

                <td>{{ item.cantidad }}</td>

                <td>
                    {{ (item.articulo.precioFinal * item.cantidad)|number_format(2) }} €
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="text-end">
        <h4>Total: {{ total|number_format(2) }} €</h4>
    </div>

    <div class="d-flex justify-content-between mt-4">
        <a href="{{ path('carrito') }}" class="btn btn-secondary">
            Volver al carrito
        </a>

        <a href="{{ path('fin_pedido') }}" class="btn btn-success">
            Finalizar pedido
        </a>
    </div>

</div>
{% endblock %}