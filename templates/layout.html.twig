{% extends 'base.html.twig' %}

{% block navbar %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('inicio') }}">Tienda</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('categorias') }}">Categorías</a>
                </li>

                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link"
                           href="{{ path('app_perfil', {username: app.user.userIdentifier}) }}">
                            Perfil
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('carrito') }}">
                            🛒 Carrito
                        </a>
                    </li>
                    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('stock') }}">
                            Stock
                        </a>
                    </li>
                     {% endif %}

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            {{ app.user.userIdentifier }} (Salir)
                        </a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_registro') }}">Registro</a>
                    </li>
                {% endif %}

            </ul>
        </div>
    </div>
</nav>

<div class="bg-secondary text-white p-4 text-center">
    <h1>Tienda de Videojuegos</h1>
    <p>Encuentra los mejores juegos en nuestra web</p>
</div>
{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% block contenido %}{% endblock %}
</div>
{% endblock %}