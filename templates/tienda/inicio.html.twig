{% extends 'layout.html.twig' %}

{% block title %}Tienda{% endblock %}

{% block contenido %}
<div class="container">
    <div class="row">

        <!-- CATEGORÍAS -->
        <div class="col-md-2">
            <h3>Categorías</h3>

            <div class="list-group">
                {% for cat in categorias %}
                    <a class="list-group-item list-group-item-action"
                       href="{{ path('categoria', {id: cat.id}) }}">
                        {{ cat.nombre }}
                    </a>
                {% endfor %}
            </div>

            {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                <br>
                <a class="btn btn-primary w-100"
                   href="{{ path('articulos_new') }}">
                    Nuevo videojuego
                </a>

                <br><br>

                <a class="btn btn-secondary w-100"
                   href="{{ path('categorias_new') }}">
                    Nueva categoría
                </a>
            {% endif %}
        </div>

        <!-- ARTÍCULOS -->
        <div class="col-md-10">
            <h3>Nuestros videojuegos</h3>

            <table class="table table-hover align-middle">
                <tr>
                    <th></th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>PVP</th>

                    {% if app.user %}
                        <th>Comprar</th>
                    {% endif %}

                    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                        <th>Modificar</th>
                        <th>Borrar</th>
                    {% endif %}
                </tr>

                {% for art in articulos %}
                <tr>
                    <td>
                        {% if art.imagen %}
                            <img src="{{ asset('img/' ~ art.imagen) }}" width="80">
                        {% else %}
                            <img src="{{ asset('img/not-found.png') }}" width="80">
                        {% endif %}
                    </td>

                    <td>{{ art.nombre }}</td>
                    <td>{{ art.descripcion }}</td>
                    <td>{{ art.precioFinal }} €</td>

                    {% if app.user %}
                        <td>
                            <a href="{{ path('carrito_add', {id: art.id}) }}"
                               class="btn btn-sm btn-success">
                                <i class="bi bi-cart"></i> Comprar
                            </a>
                        </td>
                    {% endif %}

                    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                        <td>
                            <a href="{{ path('articulos_edit', {id: art.id}) }}">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                        <td>
                            <a href="{{ path('articulos_delete', {id: art.id}) }}">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    {% endif %}
                </tr>
                {% else %}
                    <tr>
                        <td colspan="6">No hay artículos</td>
                    </tr>
                {% endfor %}
            </table>
        </div>

    </div>
</div>
{% endblock %}