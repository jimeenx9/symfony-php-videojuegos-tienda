{% extends 'layout.html.twig' %}

{% block title %}Tienda{% endblock %}

{% block contenido %}
<div class="container">
    <div class="row">
        <div class="col-md-3"></div>

        <div class="col-md-6">

            <h3>
                {% if articulo is defined %}
                    Modificando Videojuego
                {% else %}
                    Nuevo Videojuego
                {% endif %}
            </h3>

            {% if error is defined and error %}
                <div class="alert alert-danger">
                    {{ error }}
                </div>
            {% endif %}

            <form method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="nombre"
                           value="{{ articulo.nombre ?? '' }}"
                           class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Precio</label>
                    <input type="number" step="0.01" name="precio"
                           value="{{ articulo.precio ?? '' }}"
                           class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">IVA</label>
                    <input type="number" name="iva"
                           value="{{ articulo.iva ?? 21 }}"
                           class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagen</label>
                    <input type="file" name="imagen" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Stock</label>
                    <input type="number" name="stock"
                           value="{{ articulo.stock ?? '' }}"
                           class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <textarea name="descripcion"
                              rows="5"
                              class="form-control">{{ articulo.descripcion ?? '' }}</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Categoría</label>
                    <select name="categoria" class="form-control">
                        {% for cat in categorias %}
                            <option value="{{ cat.id }}"
                                {% if articulo is defined and articulo.categoria.id == cat.id %}
                                    selected
                                {% endif %}
                            >
                                {{ cat.nombre }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <button type="submit"
                        class="btn btn-lg btn-primary w-100">
                    Guardar
                </button>

            </form>
            <br>
        </div>
    </div>
</div>
{% endblock %}