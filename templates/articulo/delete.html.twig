{% extends 'layout.html.twig' %}

{% block title %}Tienda{% endblock %}

{% block contenido %}
<div class="container">
    <div class="row">
        <div class="col-md-3"></div>

        <div class="col-md-6">

            <h3>Borrar Videojuego</h3>

            <p>
                ¿Estás seguro de borrar el videojuego:
                <strong>{{ articulo.nombre }}</strong>?
            </p>

            <form method="post">
                <button type="submit"
                        class="btn btn-danger">
                    Sí, borrar
                </button>

                <a href="{{ path('inicio') }}"
                   class="btn btn-secondary">
                    Cancelar
                </a>
            </form>

        </div>
    </div>
</div>
{% endblock %}