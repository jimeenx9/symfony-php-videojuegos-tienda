{% extends 'layout.html.twig' %}

{% block title %}Control de Stock{% endblock %}

{% block contenido %}
<div class="container mt-4">

    <h2>Panel de Stock</h2>
    <br>

    <table class="table table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th></th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock actual</th>
            </tr>
        </thead>

        <tbody>
        {% for art in articulos %}
            <tr>
                <td width="90">
                    {% if art.imagen %}
                        <img src="{{ asset('img/' ~ art.imagen) }}"
                             width="70">
                    {% endif %}
                </td>

                <td>
                    <strong>{{ art.nombre }}</strong>
                </td>

                <td>
                    {{ art.precioFinal }} €
                </td>

                <td>
                    {% if art.stock > 5 %}
                        <span class="badge bg-success">
                            {{ art.stock }}
                        </span>
                    {% elseif art.stock > 0 %}
                        <span class="badge bg-warning text-dark">
                            {{ art.stock }}
                        </span>
                    {% else %}
                        <span class="badge bg-danger">
                            Sin stock
                        </span>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}